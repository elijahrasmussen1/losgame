-- STUDIO GUARD
-- =====================================================
local IS_STUDIO = RunService:IsStudio()
if IS_STUDIO then
	warn("[AdminRemote] Running in Studio — MessagingService cross-server is DISABLED in Studio.")
	warn("[AdminRemote] Announcements will still fire locally. Test cross-server in live published game.")
end

-- =====================================================
-- CREATE REMOTES IMMEDIATELY
-- =====================================================
local function getOrCreate(name, class)
	local obj = ReplicatedStorage:FindFirstChild(name)
	if not obj then
		obj        = Instance.new(class)
		obj.Name   = name
		obj.Parent = ReplicatedStorage
	end
	return obj
end

local adminRemote    = getOrCreate("AdminRemote",         "RemoteEvent")
local announceRemote = getOrCreate("AdminAnnounceRemote", "RemoteEvent")
local rainbowRemote  = getOrCreate("RainbowEventRemote",  "RemoteEvent")

-- =====================================================
-- MONEY API  (wait for MoneyService to be ready)
-- =====================================================
local apiBindable = ServerStorage:WaitForChild("MoneyAPIBindable", 30)
if not apiBindable then
	warn("[AdminRemote] MoneyAPIBindable not found — economy commands disabled")
end

local function apiCall(action, player, amount)
	if not apiBindable then return nil end
	local ok, result = pcall(function()
		return apiBindable:Invoke(action, player, amount)
	end)
	if not ok then
		warn("[AdminRemote] MoneyAPI call failed (" .. action .. "):", result)
		return nil
	end
	return result
end

