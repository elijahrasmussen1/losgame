-- made by elijxhraz
--
-- Placement system:
--   • Player equips a non-tool item, approaches a "PlacePart" and triggers
--     the "Place Brainrot" ProximityPrompt.
--   • The equipped item is removed from their backpack and its model is
--     spawned, anchored at PlacePart's Attachment.
--   • The same prompt's ActionText changes to "Pick Up" so the owner can
--     reclaim the item. Other players cannot trigger the pickup.
--   • Placed models are cleaned up when the owner leaves.

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage     = game:GetService("ServerStorage")

-- ── Wait for BackpackServer bindables ─────────────────────────────────────────
local placementBindables = ServerStorage:WaitForChild("PlacementBindables", 60)
if not placementBindables then
error("[PlacementServer] PlacementBindables not found in ServerStorage after 60s. "
.. "Ensure BackpackServer is running and has created the folder.")
end
local removeEquippedFunc = placementBindables:WaitForChild("RemoveEquippedItem")
local addItemFunc        = placementBindables:WaitForChild("AddItemToBackpack")

-- ── Model template lookup ─────────────────────────────────────────────────────
local modelsFolder = ReplicatedStorage:FindFirstChild("BrainrotModels")

local function getModelTemplate(modelName)
if not modelName or modelName == "" then return nil end
if modelsFolder then
local t = modelsFolder:FindFirstChild(modelName)
or modelsFolder:FindFirstChild(modelName, true)
if t then return t end
end
local t = ReplicatedStorage:FindFirstChild(modelName)
or ReplicatedStorage:FindFirstChild(modelName, true)
if t then return t end
local bf = workspace:FindFirstChild("Brainrots")
if bf then
t = bf:FindFirstChild(modelName, true)
if t then return t end
end
return workspace:FindFirstChild(modelName, true)
end

-- ── Placement registry ────────────────────────────────────────────────────────
-- Key: PlacePart instance
-- Value: { owner=UserId, item=itemRecord, model=clone,
--          prompt=ProximityPrompt,
--          origActionText=string, origObjectText=string }
local placedAtParts = {}

-- ── Handle placement and pickup via the same prompt ───────────────────────────
local hookedParts = {}

local function setupPlacePart(placePart)
if hookedParts[placePart] then return end
hookedParts[placePart] = true

-- Find the Attachment for snapping
local attachment = nil
if placePart:IsA("BasePart") then
attachment = placePart:FindFirstChildWhichIsA("Attachment")
else
attachment = placePart:FindFirstChildWhichIsA("Attachment", true)
end

if not attachment then
warn("[PlacementServer] PlacePart '" .. placePart.Name .. "' has no Attachment – skipping")
return
end

-- Locate the "Place Brainrot" ProximityPrompt, waiting briefly if needed
local prompt = nil

local function findPrompt(obj)
for _, d in ipairs(obj:GetDescendants()) do
if d:IsA("ProximityPrompt")
and (d.ActionText == "Place Brainrot" or d.Name == "Place Brainrot") then
return d
end
end
if obj:IsA("BasePart") then
local p = obj:FindFirstChildWhichIsA("ProximityPrompt")
if p and (p.ActionText == "Place Brainrot" or p.Name == "Place Brainrot") then
return p
end
end
return nil
end

prompt = findPrompt(placePart)

if not prompt then
local found = false
local conn
conn = placePart.DescendantAdded:Connect(function(d)
if found then return end
if d:IsA("ProximityPrompt")
and (d.ActionText == "Place Brainrot" or d.Name == "Place Brainrot") then
found  = true
prompt = d
conn:Disconnect()
end
end)
local elapsed = 0
while not found and placePart.Parent and elapsed < 10 do
task.wait(0.2)
elapsed += 0.2
end
if conn then conn:Disconnect() end
if not found then
warn("[PlacementServer] No 'Place Brainrot' ProximityPrompt on", placePart.Name)
return
end
end

-- Store original prompt text so we can restore it on pickup
local origActionText = prompt.ActionText
local origObjectText = prompt.ObjectText

prompt.Triggered:Connect(function(player)
local entry = placedAtParts[placePart]

if entry then
-- ── PICKUP ──────────────────────────────────────────────────────
-- Only the owner can pick up their own placed item
if player.UserId ~= entry.owner then return end

-- Return item to backpack
addItemFunc:Invoke(player, entry.item)

-- Destroy the placed model
if entry.model and entry.model.Parent then
entry.model:Destroy()
end

-- Reset the prompt back to "Place Brainrot"
placedAtParts[placePart] = nil
prompt.ActionText = origActionText
prompt.ObjectText = origObjectText
prompt:SetAttribute("PlacedByUserId", nil)

print("[PlacementServer]", player.Name, "picked up", entry.item.name or entry.item.modelName)

else
-- ── PLACE ───────────────────────────────────────────────────────
local itemRecord = removeEquippedFunc:Invoke(player)
if not itemRecord then
print("[PlacementServer]", player.Name, "has no placeable item equipped")
return
end

local modelName = itemRecord.modelName or itemRecord.name
local template  = getModelTemplate(modelName)
if not template then
warn("[PlacementServer] Model template not found for:", modelName, "– returning item")
addItemFunc:Invoke(player, itemRecord)
return
end

-- Clone and strip prompts/scripts so placed copy is inert
local clone = template:Clone()
clone:SetAttribute("PlacedBy", player.UserId)
clone:SetAttribute("PlacedItemName", modelName)

for _, d in ipairs(clone:GetDescendants()) do
if d:IsA("ProximityPrompt") or d:IsA("ClickDetector")
or d:IsA("Script")       or d:IsA("LocalScript") then
d:Destroy()
end
end

-- Anchor all parts
for _, p in ipairs(clone:GetDescendants()) do
if p:IsA("BasePart") then
p.Anchored   = true
p.CanCollide = true
end
end
if clone:IsA("BasePart") then
clone.Anchored   = true
clone.CanCollide = true
end

clone.Parent = workspace

-- Snap to attachment world CFrame
local attachCF = attachment.WorldCFrame
if clone.PrimaryPart then
clone:PivotTo(attachCF)
else
local root = clone:FindFirstChildWhichIsA("MeshPart", true)
or clone:FindFirstChildWhichIsA("BasePart", true)
if root then root.CFrame = attachCF end
end

-- Record the placement and update the prompt
placedAtParts[placePart] = {
owner           = player.UserId,
item            = itemRecord,
model           = clone,
prompt          = prompt,
origActionText  = origActionText,
origObjectText  = origObjectText,
}

prompt.ActionText = "Pick Up"
prompt.ObjectText = itemRecord.name or modelName
prompt:SetAttribute("PlacedByUserId", player.UserId)

print("[PlacementServer]", player.Name, "placed", modelName, "at", placePart.Name)
end
end)

print("[PlacementServer] Hooked PlacePart:", placePart.Name)
end

-- ── Watch workspace for PlacePart(s) ─────────────────────────────────────────
local function checkInstance(obj)
if obj.Name == "PlacePart" then
setupPlacePart(obj)
end
end

for _, child in ipairs(workspace:GetChildren()) do
checkInstance(child)
end
workspace.ChildAdded:Connect(checkInstance)

-- ── Clean up when the owner leaves ───────────────────────────────────────────
Players.PlayerRemoving:Connect(function(player)
for placePart, entry in pairs(placedAtParts) do
if entry.owner == player.UserId then
if entry.model and entry.model.Parent then
entry.model:Destroy()
end
-- Restore the prompt
if entry.prompt and entry.prompt.Parent then
entry.prompt.ActionText = entry.origActionText
entry.prompt.ObjectText = entry.origObjectText
entry.prompt:SetAttribute("PlacedByUserId", nil)
end
placedAtParts[placePart] = nil
end
end
end)

print("[PlacementServer] Ready")
