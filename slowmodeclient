-- SlowModeClient.client.lua
-- Place in StarterPlayerScripts
--
-- Toggles slow mode via button click OR the T key.
-- UI path: PlayerGui → ScreenGui "REAL" → Frame "LeftButtons" → Frame "SlowMode" → ImageButton "SlowModeButton"
--   ON  → ImageColor3 = (0, 255, 0), fires ToggleSlowMode(true)  to server
--   OFF → ImageColor3 restored,      fires ToggleSlowMode(false) to server

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService  = game:GetService("UserInputService")

local player    = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

print("[SlowModeClient] Starting up...")

-- Wait for the RemoteEvent (created by the server script)
local toggleRemote = ReplicatedStorage:WaitForChild("ToggleSlowMode", 30)
if not toggleRemote then
	warn("[SlowModeClient] ERROR: ToggleSlowMode RemoteEvent not found in ReplicatedStorage after 30s")
	return
end
print("[SlowModeClient] Found ToggleSlowMode remote")

-- ── Wait for UI ───────────────────────────────────────────────────────────────
-- Path: PlayerGui → ScreenGui "REAL" → Frame "LeftButtons" → Frame "SlowMode" → ImageButton "SlowModeButton"
local screenGui = playerGui:WaitForChild("REAL", 20)
if not screenGui then
	warn("[SlowModeClient] ERROR: ScreenGui 'REAL' not found in PlayerGui after 20s")
	return
end
print("[SlowModeClient] Found ScreenGui REAL")

local leftButtons = screenGui:WaitForChild("LeftButtons", 20)
if not leftButtons then
	warn("[SlowModeClient] ERROR: Frame 'LeftButtons' not found inside REAL after 20s")
	return
end
print("[SlowModeClient] Found Frame LeftButtons")

local frame = leftButtons:WaitForChild("SlowMode", 20)
if not frame then
	warn("[SlowModeClient] ERROR: Frame 'SlowMode' not found inside LeftButtons after 20s")
	return
end
print("[SlowModeClient] Found Frame SlowMode")

local button = frame:WaitForChild("SlowModeButton", 20)
if not button then
	warn("[SlowModeClient] ERROR: 'SlowModeButton' not found inside SlowMode after 20s")
	return
end
print("[SlowModeClient] Found SlowModeButton")

-- ── State ─────────────────────────────────────────────────────────────────────
local slowModeOn  = false
local normalColor = button.ImageColor3

-- ── Toggle ────────────────────────────────────────────────────────────────────
local function setSlowMode(enable)
	slowModeOn         = enable
	button.ImageColor3 = enable and Color3.fromRGB(0, 255, 0) or normalColor
	toggleRemote:FireServer(enable)
	print("[SlowModeClient] SlowMode " .. (enable and "ON" or "OFF"))
end

-- Button click
button.MouseButton1Click:Connect(function()
	setSlowMode(not slowModeOn)
end)

-- T keybind (skips if chat or another UI element has focus)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.T then
		setSlowMode(not slowModeOn)
	end
end)

print("[SlowModeClient] Ready — click SlowModeButton or press T to toggle")
