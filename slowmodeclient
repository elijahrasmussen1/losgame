-- SlowModeClient.client.lua
-- Place in StarterPlayerScripts
--
-- Toggles slow mode via button click OR the T key.
-- UI path: PlayerGui → ScreenGui "REAL" → Frame "SlowMode" → ImageButton "SlowModeButton"
--   ON  → ImageColor3 = (0, 255, 0), fires ToggleSlowMode(true)  to server
--   OFF → ImageColor3 restored,      fires ToggleSlowMode(false) to server

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService  = game:GetService("UserInputService")

local player    = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Wait for the RemoteEvent (created by the server script)
local toggleRemote = ReplicatedStorage:WaitForChild("ToggleSlowMode", 30)
if not toggleRemote then
	warn("[SlowModeClient] ToggleSlowMode remote not found")
	return
end

-- ── Wait for UI ───────────────────────────────────────────────────────────────
local screenGui = playerGui:WaitForChild("REAL",        20)
local frame     = screenGui:WaitForChild("SlowMode",    20)
local button    = frame:WaitForChild("SlowModeButton",  20)

if not button then
	warn("[SlowModeClient] SlowModeButton not found")
	return
end

-- ── State ─────────────────────────────────────────────────────────────────────
local slowModeOn  = false
local normalColor = button.ImageColor3

-- ── Toggle ────────────────────────────────────────────────────────────────────
local function setSlowMode(enable)
	slowModeOn         = enable
	button.ImageColor3 = enable and Color3.fromRGB(0, 255, 0) or normalColor
	toggleRemote:FireServer(enable)
end

-- Button click
button.MouseButton1Click:Connect(function()
	setSlowMode(not slowModeOn)
end)

-- T keybind
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.T then
		setSlowMode(not slowModeOn)
	end
end)

print("[SlowModeClient] Ready — click SlowModeButton or press T to toggle")
