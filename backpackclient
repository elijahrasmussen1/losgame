local function beginPendingDrag(item, hotbarIdx, bagIdx)
	drag.pending = true; drag.active = false
	drag.item = item; drag.srcHotbar = hotbarIdx; drag.srcBag = bagIdx
	drag.startPos = getPointerPosition()
end

local function clearDrag()
	if drag.ghost then drag.ghost:Destroy(); drag.ghost = nil end
	drag.active = false; drag.pending = false
	drag.item = nil; drag.srcHotbar = nil; drag.srcBag = nil
	drag.startPos = nil; drag.touchId = nil
end

-- ══════════════════════════════════════════════════════════════════════
-- EQUIP/UNEQUIP LOGIC (shared by click, tap, and keyboard)
-- ══════════════════════════════════════════════════════════════════════
local rebuildHotbar, rebuildBag, rebuildUI

local function handleSlotTap(hIdx, itm)
	if State.equippedSlot == hIdx then
		State.equippedSlot = nil; unequipRemote:FireServer(); detachEquipped()
		placeSlotRemote:FireServer(0)
	else
		State.equippedSlot = hIdx; equipRemote:FireServer(hIdx); attachEquipped(itm)
		placeSlotRemote:FireServer(hIdx)
	end
	rebuildHotbar()
	if State.panelOpen then rebuildBag() end
end

local function handleDrop(mp)
	local fromHotbar = drag.srcHotbar ~= nil
	local fromBag    = drag.srcBag ~= nil
	local srcH = drag.srcHotbar; local srcB = drag.srcBag
	local itm = drag.item
	local droppedInPanel = inPanelZone(mp)

	if fromHotbar then
		if droppedInPanel then
			local bHit = panelReady and hitTestFrames(bagFrames, mp) or nil
			if bHit then
				State.bag[bHit], State.hotbar[srcH] = itm, State.bag[bHit]
			else
				State.hotbar[srcH] = nil; table.insert(State.bag, itm)
			end
			if State.equippedSlot == srcH then
				State.equippedSlot = nil; unequipRemote:FireServer(); detachEquipped()
			end
		else
			local hHit = hitTestFrames(hotbarFrames, mp)
			if hHit and hHit ~= srcH then
				State.hotbar[hHit], State.hotbar[srcH] = State.hotbar[srcH], State.hotbar[hHit]
				if State.equippedSlot == srcH then State.equippedSlot = hHit
				elseif State.equippedSlot == hHit then State.equippedSlot = srcH end
			end
		end
	elseif fromBag then
		if not droppedInPanel then
			local hHit = hitTestFrames(hotbarFrames, mp)
			if hHit then
				local displaced = State.hotbar[hHit]
				State.hotbar[hHit] = itm; table.remove(State.bag, srcB)
				if displaced then
					table.insert(State.bag, displaced)
					if State.equippedSlot == hHit then
						State.equippedSlot = nil; unequipRemote:FireServer(); detachEquipped()
					end
				end
			else
				for i = 1, CFG.HOTBAR_MAX do
					if not State.hotbar[i] then
						State.hotbar[i] = itm; table.remove(State.bag, srcB); break
					end
				end
			end
		else
			local bHit = hitTestFrames(bagFrames, mp)
			if bHit and bHit ~= srcB then
				State.bag[bHit], State.bag[srcB] = State.bag[srcB], State.bag[bHit]
			end
		end
	end
	clearDrag(); rebuildUI()
	rearrangeRemote:FireServer(State.hotbar)
end

rebuildHotbar = function()
	for _, f in pairs(hotbarFrames) do if f then f:Destroy() end end
	hotbarFrames = {}
	for _, c in ipairs(UI.numRow:GetChildren()) do if c:IsA("TextLabel") then c:Destroy() end end
	UI.hotbarWrap.Size = UDim2.new(CFG.PANEL_W_SCALE, 0, 0, HOTBAR_H)
	UI.hotbarRow.Size  = UDim2.new(1, 0, 0, CFG.HOTBAR_SLOT_PX)
	UI.numRow.Size     = UDim2.new(1, 0, 0, 14)
	for i = 1, CFG.HOTBAR_MAX do
		local item = State.hotbar[i]
		-- Number label (always, even for empty slots)
		local nl = Instance.new("TextLabel")
		nl.Size = UDim2.new(0,CFG.HOTBAR_SLOT_PX,0,14); nl.BackgroundTransparency = 1
		nl.Text = tostring(i); nl.TextColor3 = CFG.C_NUM
		nl.Font = Enum.Font.GothamBold; nl.TextSize = 10
		nl.TextXAlignment = Enum.TextXAlignment.Center
		nl.LayoutOrder = i; nl.Parent = UI.numRow
		if not item then
			-- Empty slot frame
			local f = Instance.new("Frame")
			f.Size = UDim2.new(0,CFG.HOTBAR_SLOT_PX,0,CFG.HOTBAR_SLOT_PX)
			f.BackgroundColor3 = CFG.C_SLOT; f.BorderSizePixel = 0
			f.Name = "HSlot"..i; f.LayoutOrder = i; f.Parent = UI.hotbarRow
			hotbarFrames[i] = f
			mkCorner(f, UDim.new(0,CFG.HOTBAR_CORNER)); mkStroke(f, CFG.C_BORDER, 1.5)
			continue
		end
		local isEq = State.equippedSlot == i
		local f, btn = makeSlotCard(UI.hotbarRow, item,
			CFG.HOTBAR_SLOT_PX, CFG.HOTBAR_SLOT_PX, CFG.HOTBAR_CORNER, 1, isEq)
		f.Name = "HSlot"..i; f.LayoutOrder = i; hotbarFrames[i] = f

		-- Mouse down (desktop drag start)
		btn.MouseButton1Down:Connect(function()
			beginPendingDrag(item, i, nil)
		end)

		-- Touch: tap to equip, hold+drag to rearrange
		btn.TouchLongPress:Connect(function()
			beginPendingDrag(item, i, nil)
		end)
		btn.TouchTap:Connect(function()
			if not drag.active then
				handleSlotTap(i, item)
			end
		end)
	end
end

rebuildBag = function()
	for _, c in ipairs(UI.bagScroll:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
	bagFrames = {}
	for i, item in ipairs(State.bag) do
		local f, btn = makeSlotCard(UI.bagScroll, item,
			CFG.BAG_SLOT_W, CFG.BAG_SLOT_H, CFG.BAG_SLOT_CORNER, 10, false)
		f.Name = "BSlot"..i; f.LayoutOrder = i
		f:SetAttribute("BagIndex", i); bagFrames[i] = f
		btn.MouseButton1Down:Connect(function()
			beginPendingDrag(item, nil, i)
		end)
		btn.TouchLongPress:Connect(function()
			beginPendingDrag(item, nil, i)
		end)
	end
end

rebuildUI = function()
	rebuildHotbar()
	-- Update item count display
	local totalItems = 0
	for i = 1, CFG.HOTBAR_MAX do if State.hotbar[i] then totalItems += 1 end end
	totalItems += #State.bag
	UI.panelTitle.Text = totalItems .. "/100"
	if State.panelOpen then rebuildBag() end
end

