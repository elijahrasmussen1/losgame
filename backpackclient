local modelTemplateCache = {}

local CARRIABLE = {
	["NoobiniCakenini"] = true,
	["Allesina"]        = true,
	["ChillinChilitos"] = true,
}

local function cacheModelTemplate(model)
	if not model:IsA("Model") then return end
	if model:GetAttribute("EquippedDisplay") then return end
	if model:GetAttribute("PlacedBy") then return end
	local name = model.Name
	if not CARRIABLE[name] then return end
	local clone = model:Clone()
	clone.Parent = nil
	modelTemplateCache[name] = clone
end

for _, child in ipairs(workspace:GetChildren()) do
	cacheModelTemplate(child)
end
workspace.ChildAdded:Connect(function(child)
	if not child:GetAttribute("EquippedDisplay") then
		cacheModelTemplate(child)
	end
end)

local BrainrotsFolder = workspace:FindFirstChild("Brainrots")
if BrainrotsFolder then
	for _, child in ipairs(BrainrotsFolder:GetChildren()) do
		cacheModelTemplate(child)
	end
	BrainrotsFolder.ChildAdded:Connect(cacheModelTemplate)
	for _, child in ipairs(BrainrotsFolder:GetChildren()) do
		if child:IsA("Folder") or child:IsA("Model") then
			for _, grandchild in ipairs(child:GetChildren()) do
				cacheModelTemplate(grandchild)
			end
			child.ChildAdded:Connect(cacheModelTemplate)
		end
	end
	BrainrotsFolder.DescendantAdded:Connect(function(d)
		if d:IsA("Model") then cacheModelTemplate(d) end
	end)
end

local function findTemplateModel(modelName)
	if not modelName or modelName == "" then return nil end
	if modelTemplateCache[modelName] then return modelTemplateCache[modelName] end
	if modelsFolder then
		local t = modelsFolder:FindFirstChild(modelName) or modelsFolder:FindFirstChild(modelName, true)
		if t then return t end
	end
	local t = ReplicatedStorage:FindFirstChild(modelName) or ReplicatedStorage:FindFirstChild(modelName, true)
	if t then return t end
	t = StarterPack:FindFirstChild(modelName)
	if t then return t end
	local backpack = player:FindFirstChild("Backpack")
	if backpack then t = backpack:FindFirstChild(modelName); if t then return t end end
	local char = player.Character
	if char then t = char:FindFirstChild(modelName); if t then return t end end
	local bf = workspace:FindFirstChild("Brainrots")
	if bf then t = bf:FindFirstChild(modelName, true); if t then return t end end
	t = workspace:FindFirstChild(modelName)
	if t then return t end
	return workspace:FindFirstChild(modelName, true)
end

local iconCache = {}

local function resolveIcon(item)
	local overrideName = (item.name and ICON_OVERRIDES[item.name])
		or (item.modelName and ICON_OVERRIDES[item.modelName])
	if overrideName then item.icon = overrideName; return overrideName end
	if item.icon and item.icon ~= "" then return item.icon end
	local modelName = item.modelName
	if not modelName or modelName == "" then return "" end
	if iconCache[modelName] ~= nil then
		if iconCache[modelName] ~= "" then item.icon = iconCache[modelName] end
		return iconCache[modelName]
	end
	local src = findTemplateModel(modelName)
	if not src then iconCache[modelName] = ""; return "" end
	local attr = src:GetAttribute("Icon") or src:GetAttribute("Thumbnail")
	if attr and attr ~= "" then iconCache[modelName] = attr; item.icon = attr; return attr end
	for _, name in ipairs({"Icon","Thumbnail","icon","thumbnail"}) do
		local child = src:FindFirstChild(name, true)
		if child then
			local tex
			if child:IsA("Decal") or child:IsA("Texture") then tex = child.Texture
			elseif child:IsA("ImageLabel") or child:IsA("ImageButton") then tex = child.Image end
			if tex and tex ~= "" then iconCache[modelName] = tex; item.icon = tex; return tex end
		end
	end
	for _, d in ipairs(src:GetDescendants()) do
		if (d:IsA("Decal") or d:IsA("Texture")) and d.Texture ~= "" then
			iconCache[modelName] = d.Texture; item.icon = d.Texture; return d.Texture
		end
	end
	iconCache[modelName] = ""; return ""
end

local function isToolItem(item)
	if not item then return false end
	return TOOL_ITEMS[item.name] or TOOL_ITEMS[item.modelName] or false
end

local function shouldHideLevel(item)
	if not item then return false end
	return HIDE_LEVEL[item.name] or HIDE_LEVEL[item.modelName] or false
end

