local function hitTestFrames(frames, mp)
	for idx, f in pairs(frames) do
		if f and f.Visible then
			local a = f.AbsolutePosition; local s = f.AbsoluteSize
			if mp.X >= a.X and mp.X <= a.X+s.X and mp.Y >= a.Y and mp.Y <= a.Y+s.Y then return idx end
		end
	end
	return nil
end

local function makeSlotCard(parent, item, slotW, slotH, cornerR, zBase, isEq)
	zBase = zBase or 1
	local f = Instance.new("Frame")
	f.Size = UDim2.new(0,slotW,0,slotH)
	f.BackgroundColor3 = isEq and CFG.C_SLOT_EQ or CFG.C_SLOT
	f.BorderSizePixel = 0; f.Parent = parent
	mkCorner(f, UDim.new(0,cornerR))
	mkStroke(f, isEq and CFG.C_BORDER_EQ or CFG.C_BORDER, isEq and 2.5 or 1.5)

	local icon = resolveIcon(item)
	local hasOverride = (item.name and ICON_OVERRIDES[item.name] ~= nil)
		or (item.modelName and ICON_OVERRIDES[item.modelName] ~= nil)

	local ico = Instance.new("ImageLabel")
	ico.AnchorPoint = Vector2.new(0.5,0.5); ico.BackgroundTransparency = 1
	ico.Image = icon; ico.ScaleType = Enum.ScaleType.Fit; ico.ZIndex = zBase+1; ico.Parent = f
	if hasOverride then
