}

local function itemKey(item)
	return tostring(item.id or (tostring(item.name) .. "_" .. tostring(item.level or 1)))
end

local function buildItemCounts()
	local counts = {}
	for i = 1, CFG.HOTBAR_MAX do
		if State.hotbar[i] then
			local k = itemKey(State.hotbar[i])
			counts[k] = (counts[k] or 0) + 1
		end
	end
	for _, item in ipairs(State.bag) do
		local k = itemKey(item)
		counts[k] = (counts[k] or 0) + 1
	end
	return counts
end

local function insertNewItem(item)
	for i = 1, CFG.HOTBAR_MAX do
		if not State.hotbar[i] then State.hotbar[i] = item; return end
	end
	table.insert(State.bag, item)
end

local equippedModel  = nil
local equipConn      = nil
local equippedHandle = nil
local equippedIsTool = false

local function detachEquipped()
	if equipConn then equipConn:Disconnect(); equipConn = nil end
	if equippedModel and equippedModel.Parent then equippedModel:Destroy() end
	if equippedHandle and equippedHandle.Parent then equippedHandle:Destroy() end
	if equippedIsTool then unequipToolRemote:FireServer() end
	equippedModel = nil; equippedHandle = nil; equippedIsTool = false
end

local function attachEquippedTool(item)
	detachEquipped()
	if not item then return end
	local toolName = item.name or item.modelName or "BackpackGlove"
	equipToolRemote:FireServer(toolName)
	equippedIsTool = true
end

local function attachEquipped(item)
	detachEquipped()
	if not item then return end
	if isToolItem(item) then attachEquippedTool(item); return end

	local src = findTemplateModel(item.modelName)
	if not src then warn("[BackpackClient] model not found:", item.modelName); return end

	local clone = src:Clone()
	clone:SetAttribute("EquippedDisplay", true)
	clone.Name = "__Equipped_" .. item.modelName

	for _, d in ipairs(clone:GetDescendants()) do
		if d:IsA("SurfaceGui") or d:IsA("ScreenGui") or d:IsA("ProximityPrompt")
			or d:IsA("ClickDetector") or d:IsA("Script") or d:IsA("LocalScript") then
			d:Destroy()
		end
	end
	for _, d in ipairs(clone:GetDescendants()) do
		if d:IsA("BillboardGui") and d.Name ~= "StatsGui" then d:Destroy() end
	end

	local allParts = {}
	for _, p in ipairs(clone:GetDescendants()) do
		if p:IsA("BasePart") then table.insert(allParts, p) end
	end
	if #allParts == 0 then clone:Destroy(); return end

	local targetCF = hrp.CFrame * CFrame.new(0, -1, -3.5)

	local handle = Instance.new("Part")
	handle.Name = "__EquipHandle"; handle.Size = Vector3.new(0.1,0.1,0.1)
	handle.Transparency = 1; handle.CanCollide = false; handle.CastShadow = false
	handle.Anchored = true; handle.Massless = true; handle.CFrame = targetCF
	handle.Parent = workspace

	local root = clone.PrimaryPart
		or clone:FindFirstChild("Root", true)
		or clone:FindFirstChildWhichIsA("MeshPart", true)
		or clone:FindFirstChildWhichIsA("BasePart", true)

	for _, p in ipairs(allParts) do
		p.Anchored = false; p.CanCollide = false; p.CastShadow = false; p.Massless = true
	end
	clone.Parent = workspace
	if root then
		if not clone.PrimaryPart then clone.PrimaryPart = root end
		clone:PivotTo(targetCF)
	else clone:MoveTo(targetCF.Position) end

	for _, p in ipairs(allParts) do
		local w = Instance.new("WeldConstraint"); w.Part0 = handle; w.Part1 = p; w.Parent = handle
	end

	local adornPart = root or allParts[1]
	for _, d in ipairs(clone:GetDescendants()) do
		if d:IsA("BillboardGui") and d.Name == "StatsGui" then d.Adornee = adornPart; d.Enabled = true end
	end

	equippedModel = clone; equippedHandle = handle
	equipConn = RunService.Heartbeat:Connect(function()
		if not hrp or not hrp.Parent then detachEquipped(); return end
		if not equippedHandle or not equippedHandle.Parent then equipConn:Disconnect(); equipConn = nil; return end
		equippedHandle.CFrame = hrp.CFrame * CFrame.new(0, -1, -3.5)
	end)
end

