local panelReady = false

local function getViewportSize()
	return workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1280,720)
end

local function inPanelZone(mp)
	if not State.panelOpen then return false end
	local vp = getViewportSize()
	local panelW = vp.X * CFG.PANEL_W_SCALE
	local cx = vp.X * 0.5
	local bottom = vp.Y - PANEL_BOTTOM
	local left = cx - panelW * 0.5
	local top = bottom - CFG.PANEL_H
	return mp.X >= left and mp.X <= left + panelW and mp.Y >= top and mp.Y <= top + CFG.PANEL_H
end

