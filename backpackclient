syncRemote.OnClientEvent:Connect(function(data)
	-- Always rebuild from authoritative server state so that items removed
	-- server-side (e.g. on placement) are correctly cleared from the client.
	local prevEquippedSlot = State.equippedSlot
	State.equippedSlot = data.equipped
	State.hotbar = {}
	State.bag = {}
	if data.hotbar then
		for i = 1, CFG.HOTBAR_MAX do
			if data.hotbar[i] then
				local item = data.hotbar[i]
				if not item.level then item.level = 1 end
				resolveIcon(item); State.hotbar[i] = item
			end
		end
	end
	if data.bag then
		for _, item in ipairs(data.bag) do
			if not item.level then item.level = 1 end
			resolveIcon(item); table.insert(State.bag, item)
		end
	end
	-- If server cleared the equipped slot (e.g. after placement), detach the
	-- equipped display model so it doesn't linger on the character.
	if prevEquippedSlot and not data.equipped then
		detachEquipped()
	end
	rebuildUI()
end)

brainrotCollected.OnClientEvent:Connect(function(_slot, itemRecord)
	if itemRecord and itemRecord.modelName then resolveIcon(itemRecord) end
	for _, gui in ipairs(playerGui:GetChildren()) do
		if gui.Name == "TimerGui" or gui.Name == "TimerDisplay" then gui.Enabled = false end
	end
	for _, d in ipairs(workspace:GetDescendants()) do
		if d:IsA("BillboardGui") and d.Name == "TimerGui" then d.Enabled = false end
	end
end)

local tiOpen  = TweenInfo.new(CFG.TWEEN_IN,  Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local tiClose = TweenInfo.new(CFG.TWEEN_OUT, Enum.EasingStyle.Quart, Enum.EasingDirection.In)

local function toggleBackpack()
	State.panelOpen = not State.panelOpen
	if State.panelOpen then
		panelReady = false; UI.panel.Visible = true; UI.panel.Position = PANEL_HIDE
		local tw = TweenService:Create(UI.panel, tiOpen, {Position = PANEL_SHOW})
		tw:Play(); tw.Completed:Once(function() panelReady = true; rebuildBag() end)
		UI.toggleStroke.Color = CFG.C_BTN_OPEN
	else
		panelReady = false
		local tw = TweenService:Create(UI.panel, tiClose, {Position = PANEL_HIDE})
		tw:Play(); tw.Completed:Once(function() UI.panel.Visible = false end)
		UI.toggleStroke.Color = CFG.C_BTN_BORDER
	end
end
UI.toggleBtn.MouseButton1Click:Connect(toggleBackpack)
-- Mobile: also respond to TouchTap on toggle button
UI.toggleBtn.TouchTap:Connect(toggleBackpack)

local KEY_SLOTS = {
	[Enum.KeyCode.One]=1, [Enum.KeyCode.Two]=2, [Enum.KeyCode.Three]=3,
	[Enum.KeyCode.Four]=4, [Enum.KeyCode.Five]=5, [Enum.KeyCode.Six]=6,
	[Enum.KeyCode.Seven]=7, [Enum.KeyCode.Eight]=8, [Enum.KeyCode.Nine]=9,
	[Enum.KeyCode.Zero]=10,
}
UserInputService.InputBegan:Connect(function(inp, proc)
	if proc then return end
	if inp.KeyCode == Enum.KeyCode.Tab or inp.KeyCode == Enum.KeyCode.B then
		toggleBackpack(); return
	end
	local s = KEY_SLOTS[inp.KeyCode]
	if s and State.hotbar[s] then handleSlotTap(s, State.hotbar[s]) end
end)

