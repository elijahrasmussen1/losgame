-- INPUT HANDLING: mouse + touch unified
-- ══════════════════════════════════════════════════════════════════════
UserInputService.InputChanged:Connect(function(inp)
	local isMove = inp.UserInputType == Enum.UserInputType.MouseMovement
		or inp.UserInputType == Enum.UserInputType.Touch
	if not isMove then return end

	local mp = Vector2.new(inp.Position.X, inp.Position.Y)

	if drag.active and drag.ghost then
		drag.ghost.Position = UDim2.fromOffset(mp.X, mp.Y)
		return
	end
	if drag.pending and drag.startPos then
		local dx = mp.X - drag.startPos.X
		local dy = mp.Y - drag.startPos.Y
		if math.abs(dx) > CFG.DRAG_THRESHOLD or math.abs(dy) > CFG.DRAG_THRESHOLD then
			drag.active = true; drag.pending = false
			drag.ghost = makeGhost(drag.item)
			drag.ghost.Position = UDim2.fromOffset(mp.X, mp.Y)
		end
	end
end)

UserInputService.InputEnded:Connect(function(inp)
	local isRelease = inp.UserInputType == Enum.UserInputType.MouseButton1
		or inp.UserInputType == Enum.UserInputType.Touch
	if not isRelease then return end

	if drag.pending then
		local hIdx = drag.srcHotbar
		local itm  = drag.item
		clearDrag()
		-- Only handle equip for mouse — touch uses TouchTap
		if hIdx and itm and inp.UserInputType == Enum.UserInputType.MouseButton1 then
			handleSlotTap(hIdx, itm)
		end
		return
	end

	if not drag.active then return end

	local mp = Vector2.new(inp.Position.X, inp.Position.Y)
	handleDrop(mp)
end)

