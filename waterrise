local RunService        = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage     = game:GetService("ServerStorage")

-- ====== SETTINGS ======
local RISE_SPEED        = 6
local LOWER_SPEED       = 50
local PAUSE_AT_MAX      = 12
local CYCLE_TIME        = 40
local COUNTDOWN_SECONDS = 5
-- ======================

local countdownEvent = Instance.new("RemoteEvent")
countdownEvent.Name   = "WaterCountdownEvent"
countdownEvent.Parent = ReplicatedStorage

-- NEW: dedicated event so client can play the "1" sound cleanly
local waterAlertEvent = Instance.new("RemoteEvent")
waterAlertEvent.Name   = "WaterAlertEvent"
waterAlertEvent.Parent = ReplicatedStorage

-- ── Water config ──────────────────────────────────────────────────────────────
local waterConfigs = {
	{
		name   = "Water",
		startY = -9.282,
		maxY   = -1.082,
	},
	{
		name   = "Water2",
		startY = -12.556,
		maxY   = -4.356,
	},
	{
		name   = "Water3",
		startY = -9.867,
		maxY   = -1.167,
	},
	{
		name   = "Water4",
		startY = -9.867,
		maxY   = -1.167,
	},
	{
		name   = "Water5",
		startY = -16.082,
		maxY   =  6.918,
	},
	{
		name   = "Water6",
		startY = -19.121,
		maxY   =  11.879,
	},
	{
		name   = "Water7",
		startY = -33.446,  -- 57 studs below maxY
		maxY   =  23.554,
	},
	{
		name   = "Water8",
		startY = -35.534,  -- 61 studs below maxY
		maxY   =  25.466,
	},
	{
		name   = "Water9",
		startY = -86.331,  -- 127 studs below maxY
		maxY   =  40.669,
	},
}
-- ──────────────────────────────────────────────────────────────────────────────

local waterEntries = {}

for _, config in ipairs(waterConfigs) do
	local waterPart = workspace:WaitForChild(config.name, 10)
	if not waterPart then
		warn("[WaterRise] Missing part: " .. config.name)
		continue
	end

	waterPart.Anchored = true

	table.insert(waterEntries, {
		part   = waterPart,
		startY = config.startY,
		maxY   = config.maxY,
	})

	print(string.format("[WaterRise] Registered: %s  startY=%.3f  maxY=%.3f",
		config.name, config.startY, config.maxY))
end

-- ── Helpers ───────────────────────────────────────────────────────────────────
local function setWaterY(entry, y)
	entry.part.Position = Vector3.new(entry.part.Position.X, y, entry.part.Position.Z)
end

local function resetAll()
	for _, e in ipairs(waterEntries) do
		setWaterY(e, e.startY)
	end
end

local function showCountdown(number)
	countdownEvent:FireAllClients("show", number)
end

local function hideCountdown()
	countdownEvent:FireAllClients("hide")
end

local function runCountdown()
	for i = COUNTDOWN_SECONDS, 1, -1 do
		showCountdown(i)
		-- Fire the alert sound event when countdown reaches 1
		if i == 1 then
			waterAlertEvent:FireAllClients()
		end
		task.wait(1)
	end
	hideCountdown()
end

-- ── State ─────────────────────────────────────────────────────────────────────
local userPaused      = false
local overflowRunning = false

local overflowEndSignal        = Instance.new("BindableEvent")
overflowEndSignal.Name         = "OverflowEndSignal"
overflowEndSignal.Parent       = script

-- ── Water API ─────────────────────────────────────────────────────────────────
local waterAPI        = Instance.new("BindableFunction")
waterAPI.Name         = "WaterAPIBindable"
waterAPI.Parent       = ServerStorage

waterAPI.OnInvoke = function(action, value)
	if action == "SetRiseSpeed" then
		local v = tonumber(value)
		if v and v > 0 then RISE_SPEED = v end
	elseif action == "SetLowerSpeed" then
		local v = tonumber(value)
		if v and v > 0 then LOWER_SPEED = v end
	elseif action == "Pause" then
		userPaused = true
	elseif action == "Resume" then
		userPaused = false
	elseif action == "Overflow" then
		if not overflowRunning then
			overflowRunning = true
			task.spawn(function()
				local elapsed2  = 0
				local startYs   = {}
				for i, e in ipairs(waterEntries) do
					startYs[i] = e.part.Position.Y
				end
				local ended  = false
				local endConn
				endConn = overflowEndSignal.Event:Connect(function()
					ended = true
				end)
				while not ended and elapsed2 < 45 do
					local dt = RunService.Heartbeat:Wait()
					elapsed2 += dt
					for i, e in ipairs(waterEntries) do
						setWaterY(e, startYs[i] + elapsed2 * RISE_SPEED)
					end
				end
				endConn:Disconnect()
				resetAll()
				overflowRunning = false
			end)
		end
	elseif action == "EndOverflow" then
		overflowEndSignal:Fire()
	end
	return true
end

-- ── Main cycle loop ───────────────────────────────────────────────────────────
print("[WaterRise] System started.")
resetAll()

while true do
	-- Wait for any active overflow to complete before starting a new cycle
	while overflowRunning do task.wait(0.1) end

	local riseDist = 0
	for _, e in ipairs(waterEntries) do
		riseDist = math.max(riseDist, e.maxY - e.startY)
	end
	local riseTime  = riseDist / RISE_SPEED
	local lowerTime = riseDist / LOWER_SPEED
	local usedTime  = riseTime + PAUSE_AT_MAX + lowerTime + COUNTDOWN_SECONDS
	local idleTime  = math.max(0, CYCLE_TIME - usedTime)

	-- Idle wait (interruptible by overflow or pause)
	local idleElapsed = 0
	while idleElapsed < idleTime do
		if overflowRunning then break end
		if userPaused then task.wait(0.05) continue end
		local dt = RunService.Heartbeat:Wait()
		idleElapsed += dt
	end
	if overflowRunning then continue end

	runCountdown()
	if overflowRunning then continue end

	-- Rise
	print("[WaterRise] Rising...")
	local elapsed = 0
	local totalRiseTime = riseDist / RISE_SPEED
	while elapsed < totalRiseTime do
		if overflowRunning then break end
		if userPaused then task.wait(0.05) continue end
		local dt = RunService.Heartbeat:Wait()
		elapsed += dt
		local t = math.min(elapsed / totalRiseTime, 1)
		for _, e in ipairs(waterEntries) do
			setWaterY(e, e.startY + (e.maxY - e.startY) * t)
		end
	end
	if overflowRunning then continue end
	for _, e in ipairs(waterEntries) do
		setWaterY(e, e.maxY)
	end

	-- Pause at max
	print("[WaterRise] Pausing at max for " .. PAUSE_AT_MAX .. "s.")
	local pauseElapsed = 0
	while pauseElapsed < PAUSE_AT_MAX do
		if overflowRunning then break end
		if userPaused then task.wait(0.05) continue end
		local dt = RunService.Heartbeat:Wait()
		pauseElapsed += dt
	end
	if overflowRunning then continue end

	-- Lower
	print("[WaterRise] Lowering...")
	elapsed = 0
	local totalLowerTime = riseDist / LOWER_SPEED
	while elapsed < totalLowerTime do
		if overflowRunning then break end
		if userPaused then task.wait(0.05) continue end
		local dt = RunService.Heartbeat:Wait()
		elapsed += dt
		local t = math.min(elapsed / totalLowerTime, 1)
		for _, e in ipairs(waterEntries) do
			setWaterY(e, e.maxY - (e.maxY - e.startY) * t)
		end
	end
	if overflowRunning then continue end
	for _, e in ipairs(waterEntries) do
		setWaterY(e, e.startY)
	end

	print("[WaterRise] Cycle complete.")
end
