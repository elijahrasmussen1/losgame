local RunService        = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage     = game:GetService("ServerStorage")

-- ====== SETTINGS ======
local RISE_SPEED        = 20
local LOWER_SPEED       = 50
local PAUSE_AT_MAX      = 12
local CYCLE_TIME        = 40
local COUNTDOWN_SECONDS = 5
-- ======================

local countdownEvent = Instance.new("RemoteEvent")
countdownEvent.Name   = "WaterCountdownEvent"
countdownEvent.Parent = ReplicatedStorage

-- NEW: dedicated event so client can play the "1" sound cleanly
local waterAlertEvent = Instance.new("RemoteEvent")
waterAlertEvent.Name   = "WaterAlertEvent"
waterAlertEvent.Parent = ReplicatedStorage

-- ── Water config ──────────────────────────────────────────────────────────────
local waterConfigs = {
	{
		name   = "Water",
		startY = -9.282,
		maxY   = -1.082,
	},
	{
		name   = "Water2",
		startY = -12.556,
		maxY   = -4.356,
	},
	{
		name   = "Water3",
		startY = -9.867,
		maxY   = -1.167,
	},
	{
		name   = "Water4",
		startY = -9.867,
		maxY   = -1.167,
	},
	{
		name   = "Water5",
		startY = -16.082,
		maxY   =  6.918,
	},
	{
		name   = "Water6",
		startY = -19.121,
		maxY   =  11.879,
	},
	{
		name   = "Water7",
		startY = -33.446,  -- 57 studs below maxY
		maxY   =  23.554,
	},
	{
		name   = "Water8",
		startY = -35.534,  -- 61 studs below maxY
		maxY   =  25.466,
	},
	{
		name   = "Water9",
		startY = -86.331,  -- 127 studs below maxY
		maxY   =  40.669,
	},
}
-- ──────────────────────────────────────────────────────────────────────────────

local waterEntries = {}

for _, config in ipairs(waterConfigs) do
	local waterPart = workspace:WaitForChild(config.name, 10)
	if not waterPart then
		warn("[WaterRise] Missing part: " .. config.name)
		continue
	end

	waterPart.Anchored = true

	table.insert(waterEntries, {
		part       = waterPart,
		origParent = waterPart.Parent,
		startY     = config.startY,
		maxY       = config.maxY,
		startSizeY = waterPart.Size.Y,
		startMat   = waterPart.Material,
	})

	print(string.format("[WaterRise] Registered: %s  startY=%.3f  maxY=%.3f",
		config.name, config.startY, config.maxY))
end

-- ── Helpers ───────────────────────────────────────────────────────────────────
local function setWaterY(entry, y)
	entry.part.Position = Vector3.new(entry.part.Position.X, y, entry.part.Position.Z)
end

local function resetAll()
	for _, e in ipairs(waterEntries) do
		setWaterY(e, e.startY)
		e.part.Size = Vector3.new(e.part.Size.X, e.startSizeY, e.part.Size.Z)
	end
end

local function showCountdown(number)
	countdownEvent:FireAllClients("show", number)
end

local function hideCountdown()
	countdownEvent:FireAllClients("hide")
end

local function runCountdown()
	for i = COUNTDOWN_SECONDS, 1, -1 do
		showCountdown(i)
		-- Fire the alert sound event when countdown reaches 1
		if i == 1 then
			waterAlertEvent:FireAllClients()
		end
		task.wait(1)
	end
	hideCountdown()
end

-- ── State ─────────────────────────────────────────────────────────────────────
local userPaused      = false
local overflowRunning = false
local nukeActive      = false

local overflowEndSignal        = Instance.new("BindableEvent")
overflowEndSignal.Name         = "OverflowEndSignal"
overflowEndSignal.Parent       = script

-- ── Water API ─────────────────────────────────────────────────────────────────
local waterAPI        = Instance.new("BindableFunction")
waterAPI.Name         = "WaterAPIBindable"
waterAPI.Parent       = ServerStorage

waterAPI.OnInvoke = function(action, value)
	if action == "SetRiseSpeed" then
		local v = tonumber(value)
		if v and v > 0 then RISE_SPEED = v end
	elseif action == "SetLowerSpeed" then
		local v = tonumber(value)
		if v and v > 0 then LOWER_SPEED = v end
	elseif action == "SetCycleTime" then
		local v = tonumber(value)
		if v and v > 0 then CYCLE_TIME = v end
	elseif action == "SetCountdown" then
		local v = tonumber(value)
		if v and v >= 0 then COUNTDOWN_SECONDS = math.floor(v) end
	elseif action == "SetPauseAtMax" then
		local v = tonumber(value)
		if v and v >= 0 then PAUSE_AT_MAX = v end
	elseif action == "ResetDefaults" then
		RISE_SPEED        = 20
		LOWER_SPEED       = 50
		PAUSE_AT_MAX      = 12
		CYCLE_TIME        = 40
		COUNTDOWN_SECONDS = 5
		userPaused        = false
		if overflowRunning then overflowEndSignal:Fire() end
		if nukeActive then
			nukeActive = false
			for _, e in ipairs(waterEntries) do
				e.part.Parent     = e.origParent
				e.part.CanCollide = true
				e.part.CanTouch   = true
				e.part.Material   = e.startMat
			end
			resetAll()
		end
	elseif action == "Pause" then
		userPaused = true
	elseif action == "Resume" then
		userPaused = false
	elseif action == "Overflow" then
		if not overflowRunning then
			overflowRunning = true
			task.spawn(function()
				local elapsed2  = 0
				-- Capture the bottom Y and original size of each part so we
				-- scale upward from the bottom (part grows, bottom stays fixed).
				local bottomYs  = {}
				local origSizes = {}
				for i, e in ipairs(waterEntries) do
					origSizes[i] = e.part.Size.Y
					bottomYs[i]  = e.part.Position.Y - origSizes[i] * 0.5
				end
				local ended  = false
				local endConn
				endConn = overflowEndSignal.Event:Connect(function()
					ended = true
				end)
				while not ended do
					local dt = RunService.Heartbeat:Wait()
					elapsed2 += dt
					for i, e in ipairs(waterEntries) do
						local newSizeY = origSizes[i] + elapsed2 * RISE_SPEED
						e.part.Size     = Vector3.new(e.part.Size.X, newSizeY, e.part.Size.Z)
						e.part.Position = Vector3.new(e.part.Position.X, bottomYs[i] + newSizeY * 0.5, e.part.Position.Z)
					end
				end
				endConn:Disconnect()
				resetAll()
				overflowRunning = false
			end)
		end
	elseif action == "EndOverflow" then
		overflowEndSignal:Fire()
	elseif action == "NukeWater" then
		if not nukeActive then
			nukeActive = true
			-- End any running overflow first
			overflowEndSignal:Fire()
			task.spawn(function()
				for _, e in ipairs(waterEntries) do
					-- Capture world position BEFORE reparenting
					local pos = e.part.Position
					-- Spawn large explosion at the part's last known position
					local exp = Instance.new("Explosion")
					exp.Position                  = pos
					exp.BlastRadius               = 60
					exp.BlastPressure             = 0
					exp.ExplosionType             = Enum.ExplosionType.NoCraters
					exp.DestroyJointRadiusPercent = 0
					exp.Parent                    = workspace
					-- Move part out of Workspace entirely — this is the only 100%
					-- reliable way to kill both rendering and physics in Roblox.
					e.part.CanCollide = false
					e.part.CanTouch   = false
					e.part.Parent     = ServerStorage
					task.wait(0.05) -- stagger cascade
				end
			end)
		end
	elseif action == "EndNuke" then
		if nukeActive then
			nukeActive = false
			for _, e in ipairs(waterEntries) do
				-- Restore to original parent so it appears in the world again
				e.part.Parent     = e.origParent
				e.part.CanCollide = true
				e.part.CanTouch   = true
				e.part.Material   = e.startMat
			end
			resetAll()
		end
	end
	return true
end

-- ── Main cycle loop ───────────────────────────────────────────────────────────
print("[WaterRise] System started.")
resetAll()

while true do
	-- Wait for any active overflow or nuke to complete before starting a new cycle
	while overflowRunning or nukeActive do task.wait(0.1) end

	local riseDist = 0
	for _, e in ipairs(waterEntries) do
		riseDist = math.max(riseDist, e.maxY - e.startY)
	end
	local riseTime  = riseDist / RISE_SPEED
	local lowerTime = riseDist / LOWER_SPEED
	local usedTime  = riseTime + PAUSE_AT_MAX + lowerTime + COUNTDOWN_SECONDS
	local idleTime  = math.max(0, CYCLE_TIME - usedTime)

	-- Idle wait (interruptible by overflow or pause)
	local idleElapsed = 0
	while idleElapsed < idleTime do
		if overflowRunning or nukeActive then break end
		if userPaused then task.wait(0.05) continue end
		local dt = RunService.Heartbeat:Wait()
		idleElapsed += dt
	end
	if overflowRunning or nukeActive then continue end

	runCountdown()
	if overflowRunning or nukeActive then continue end

	-- Rise
	print("[WaterRise] Rising...")
	local elapsed = 0
	local totalRiseTime = riseDist / RISE_SPEED
	while elapsed < totalRiseTime do
		if overflowRunning or nukeActive then break end
		if userPaused then task.wait(0.05) continue end
		local dt = RunService.Heartbeat:Wait()
		elapsed += dt
		local t = math.min(elapsed / totalRiseTime, 1)
		for _, e in ipairs(waterEntries) do
			setWaterY(e, e.startY + (e.maxY - e.startY) * t)
		end
	end
	if overflowRunning or nukeActive then continue end
	for _, e in ipairs(waterEntries) do
		setWaterY(e, e.maxY)
	end

	-- Pause at max
	print("[WaterRise] Pausing at max for " .. PAUSE_AT_MAX .. "s.")
	local pauseElapsed = 0
	while pauseElapsed < PAUSE_AT_MAX do
		if overflowRunning or nukeActive then break end
		if userPaused then task.wait(0.05) continue end
		local dt = RunService.Heartbeat:Wait()
		pauseElapsed += dt
	end
	if overflowRunning or nukeActive then continue end

	-- Lower
	print("[WaterRise] Lowering...")
	elapsed = 0
	local totalLowerTime = riseDist / LOWER_SPEED
	while elapsed < totalLowerTime do
		if overflowRunning or nukeActive then break end
		if userPaused then task.wait(0.05) continue end
		local dt = RunService.Heartbeat:Wait()
		elapsed += dt
		local t = math.min(elapsed / totalLowerTime, 1)
		for _, e in ipairs(waterEntries) do
			setWaterY(e, e.maxY - (e.maxY - e.startY) * t)
		end
	end
	if overflowRunning or nukeActive then continue end
	for _, e in ipairs(waterEntries) do
		setWaterY(e, e.startY)
	end

	print("[WaterRise] Cycle complete.")
end
