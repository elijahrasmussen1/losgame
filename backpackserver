print("[BackpackServer] Remotes created")

local playerData       = {}
local carryingBrainrot = {}
local collectDebounce  = {}
local pendingPlaceSlot = {}

-- Items that are tools and cannot be placed in the world
local TOOL_ITEMS = {
	["BackpackGlove"] = true,
}

-- ── Track client-reported equipped slot for reliable placement ────────────────
placeSlotRemote.OnServerEvent:Connect(function(player, slot)
	if type(slot) == "number" and slot >= 0 and slot <= 10 then
		pendingPlaceSlot[player] = (slot > 0) and slot or nil
	end
end)

--------------------------------------------------------
-- LOGICAL AUTO-GRANT OF BackpackGlove ON JOIN
--------------------------------------------------------
local function ensureBackpackGloveInInventory(player)
	local data = playerData[player] or {}
	local GLOVE_NAME = "BackpackGlove"
	-- Check if already present (hotbar or items)
	for i = 1, 10 do
		local itm = data.hotbar and data.hotbar[i]
		if itm and (itm.name == GLOVE_NAME or itm.modelName == GLOVE_NAME) then
			print("[BackpackServer] BackpackGlove: already present in hotbar for", player.Name)
			return
		end
	end
	if data.items then
		for _, item in ipairs(data.items) do
			if item.name == GLOVE_NAME or item.modelName == GLOVE_NAME then
				print("[BackpackServer] BackpackGlove: already present in bag/items for", player.Name)
				return
			end
		end
	end

	-- Find the Tool in ReplicatedStorage for attributes
	local tool = ReplicatedStorage:FindFirstChild(GLOVE_NAME)
	if not tool or not tool:IsA("Tool") then
		warn("[BackpackServer] BackpackGlove Tool not found in ReplicatedStorage!")
		return
	end
	-- Build the item entry as your system expects
	local icon = tool:GetAttribute("Icon") or ""
	local itemEntry = {
		name = GLOVE_NAME,
		icon = icon,
		modelName = GLOVE_NAME,
		level = 1
	}
	if not data.hotbar then data.hotbar = {} end
	if not data.items then data.items = {} end
	-- Add to first free hotbar slot if possible
	for i = 1, 10 do
		if not data.hotbar[i] then
			data.hotbar[i] = itemEntry
			table.insert(data.items, itemEntry)
			print("[BackpackServer] BackpackGlove auto-added to hotbar slot", i, "for", player.Name)
			return
		end
	end
	-- Otherwise, add to items (the bag)
	table.insert(data.items, itemEntry)
	print("[BackpackServer] BackpackGlove auto-added to bag for", player.Name)
end

local function getPlayerData(player)
	if not playerData[player] then
		playerData[player] = { items = {}, equipped = nil, hotbar = {} }
	end
	return playerData[player]
end

-- ── DataStore helpers ─────────────────────────────────────────────────────────
local function loadPlayerData(player)
	local ok, saved = pcall(function()
		return backpackStore:GetAsync(tostring(player.UserId))
	end)
	if ok and type(saved) == "table" then
		playerData[player] = {
			items    = saved.items   or {},
			equipped = nil,
			hotbar   = saved.hotbar  or {},
		}
		print("[BackpackServer] Loaded data for", player.Name)
	else
		playerData[player] = { items = {}, equipped = nil, hotbar = {} }
		if not ok then
			warn("[BackpackServer] DataStore load failed for", player.Name, ":", saved)
		end
	end
end

local function nextFreeSlot(data)
	for i = 1, 10 do
		if not data.hotbar[i] then return i end
	end
	return nil
end

local function savePlayerData(player)
	local data = playerData[player]
	if not data then return end

	-- Collect any currently-placed items back into the data before saving.
	-- Look up PlacementBindables dynamically so this works regardless of
	-- declaration order (avoids the forward-reference / nil-upvalue bug).
	local pb = ServerStorage:FindFirstChild("PlacementBindables")
	local retrievePlaced = pb and pb:FindFirstChild("RetrievePlacedItems")
	if retrievePlaced then
		local ok, placed = pcall(function() return retrievePlaced:Invoke(player) end)
		if ok and type(placed) == "table" then
			for _, item in ipairs(placed) do
				local slot = nextFreeSlot(data)
				if slot then
					data.hotbar[slot] = item
				end
				table.insert(data.items, item)
			end
		end
	end

	local savePayload = { hotbar = data.hotbar, items = data.items }
	local ok2, err = pcall(function()
		backpackStore:SetAsync(tostring(player.UserId), savePayload)
	end)
	if ok2 then
		print("[BackpackServer] Saved data for", player.Name)
	else
		warn("[BackpackServer] DataStore save failed for", player.Name, ":", err)
	end
end

local function syncToClient(player)
	syncRemote:FireClient(player, getPlayerData(player))
end

local function getRoot(model)
	return model:FindFirstChild("Root", true)
		or model.PrimaryPart
		or model:FindFirstChildWhichIsA("MeshPart", true)
		or model:FindFirstChildWhichIsA("BasePart", true)
end

local function removeCarryWelds(model)
	for _, d in ipairs(model:GetDescendants()) do
		if d.Name == "CarryWeld" then d:Destroy() end
	end
end

-- Gets the full height of the model from its bounding box
local function getModelHalfHeight(model)
	local cf, size = model:GetBoundingBox()
	return size.Y / 2
end

local function getGroundY(position, model)
	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude

	local excludeList = { model }
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Character then
			table.insert(excludeList, p.Character)
		end
	end
	raycastParams.FilterDescendantsInstances = excludeList

	local origin    = Vector3.new(position.X, position.Y + 10, position.Z)
	local direction = Vector3.new(0, -500, 0)
	local result    = workspace:Raycast(origin, direction, raycastParams)

	if result then
		return result.Position.Y
	end

	-- Fallback: nearest Baseplate
	local best     = nil
	local bestDist = math.huge
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj.Name == "Baseplate" and obj:IsA("BasePart") then
			local dist = (Vector3.new(obj.Position.X, 0, obj.Position.Z) - Vector3.new(position.X, 0, position.Z)).Magnitude
			if dist < bestDist then
				bestDist = dist
				best     = obj
			end
		end
	end

	if best then
		return best.Position.Y + best.Size.Y / 2
	end

	return position.Y
end

local function dropModel(model, referencePosition)
	if not model or not model.Parent then return end

	local root = getRoot(model)
	if not root then return end

	-- 1. Anchor everything FIRST before removing welds
	--    so parts don't fall during the weld removal frame
	for _, p in ipairs(model:GetDescendants()) do
		if p:IsA("BasePart") then
			p.Anchored   = true
			p.CanCollide = false
			pcall(function() p:SetNetworkOwner(nil) end)
		end
	end

	-- 2. Now safely remove welds
	removeCarryWelds(model)

	-- 3. Wait for engine to process
	task.wait(0.1)

	if not model or not model.Parent then return end

	-- 4. Raycast from reference position downward for ground
	local groundY      = getGroundY(referencePosition, model)
	local halfHeight   = getModelHalfHeight(model)
	local finalPos     = Vector3.new(referencePosition.X, groundY + halfHeight + 0.05, referencePosition.Z)

	-- 5. Move entire model using PivotTo so all parts move together correctly
	if model.PrimaryPart then
		model:PivotTo(CFrame.new(finalPos))
	else
		root.CFrame = CFrame.new(finalPos)
	end

	-- 6. Re-anchor after move to lock in position
	for _, p in ipairs(model:GetDescendants()) do
		if p:IsA("BasePart") then
			p.Anchored   = true
			p.CanCollide = false
		end
	end

	print("[BackpackServer] Dropped", model.Name, "at", finalPos)
end

-- ── SetCarrying ───────────────────────────────────────────────────────────────
setCarryingRemote.OnServerEvent:Connect(function(player, model)
	if model and model:IsA("Model") then
		carryingBrainrot[player] = model

		local root = getRoot(model)

		for _, p in ipairs(model:GetDescendants()) do
			if p:IsA("BasePart") then
				p.Anchored   = false
				p.CanCollide = false
			end
		end

		if root then
			for _, p in ipairs(model:GetDescendants()) do
				if p:IsA("BasePart") and p ~= root then
					if not p:FindFirstChild("CarryWeld") then
						local w  = Instance.new("WeldConstraint")
						w.Name   = "CarryWeld"
						w.Part0  = root
						w.Part1  = p
						w.Parent = p
					end
				end
			end
			pcall(function() root:SetNetworkOwner(player) end)
		end

		print("[BackpackServer]", player.Name, "is carrying:", model.Name)
	else
		local prev = carryingBrainrot[player]
		carryingBrainrot[player] = nil
		if prev and prev.Parent then
			local character = player.Character
			local hrp       = character and character:FindFirstChild("HumanoidRootPart")
			local dropPos   = hrp and (hrp.CFrame * CFrame.new(0, 0, -3.5)).Position or Vector3.new(0, 5, 0)
			task.spawn(function()
				dropModel(prev, dropPos)
			end)
		end
	end
end)

-- ── Handle player death while carrying ───────────────────────────────────────
Players.PlayerAdded:Connect(function(player)
	loadPlayerData(player)
	local data = getPlayerData(player)
	ensureBackpackGloveInInventory(player)

	player.CharacterAdded:Connect(function(character)
		local humanoid = character:WaitForChild("Humanoid")
		humanoid.Died:Connect(function()
			local model = carryingBrainrot[player]
			if model and model.Parent then
				local hrp    = character:FindFirstChild("HumanoidRootPart")
				local refPos = hrp and hrp.Position or Vector3.new(0, 5, 0)
				carryingBrainrot[player] = nil
				stopCarryRemote:FireClient(player)
				task.spawn(function()
					dropModel(model, refPos)
				end)
			end
		end)

		task.wait(1)
		syncToClient(player)
	end)
end)

-- ── StartArea touch → collect ─────────────────────────────────────────────────
local StartArea = workspace:WaitForChild("StartArea", 20)
if StartArea then
	print("[BackpackServer] StartArea found:", StartArea.ClassName)

	local function onTouched(hit)
		local character = hit.Parent
		if not character then return end
		local player = Players:GetPlayerFromCharacter(character)
		if not player or collectDebounce[player] then return end

		local model = carryingBrainrot[player]
		if not model or not model.Parent then return end

		collectDebounce[player] = true

		local data = getPlayerData(player)
		local slot = nextFreeSlot(data)

		if slot then
			local itemRecord = {
				name      = model.Name,
				icon      = model:GetAttribute("Icon") or "",
				modelName = model.Name,
			}
			data.hotbar[slot] = itemRecord
			table.insert(data.items, itemRecord)

			stopCarryRemote:FireClient(player)
			brainrotCollected:FireClient(player, slot, itemRecord)
			model:Destroy()
			carryingBrainrot[player] = nil
			syncToClient(player)
			print("[BackpackServer]", player.Name, "collected", itemRecord.name, "into slot", slot)
		else
			warn("[BackpackServer]", player.Name, "hotbar is full!")
		end

		task.wait(1)
		collectDebounce[player] = nil
	end

	if StartArea:IsA("BasePart") then
		StartArea.Touched:Connect(onTouched)
	else
		for _, part in ipairs(StartArea:GetDescendants()) do
			if part:IsA("BasePart") then part.Touched:Connect(onTouched) end
		end
		StartArea.DescendantAdded:Connect(function(part)
			if part:IsA("BasePart") then part.Touched:Connect(onTouched) end
		end)
	end
else
	warn("[BackpackServer] StartArea not found!")
end

-- ── Equip / Unequip ───────────────────────────────────────────────────────────
equipRemote.OnServerEvent:Connect(function(player, slotIndex)
	local data = getPlayerData(player)
	if data.hotbar[slotIndex] then
		data.equipped = slotIndex
		syncToClient(player)
	end
end)

unequipRemote.OnServerEvent:Connect(function(player)
	local data = getPlayerData(player)
	data.equipped = nil
	syncToClient(player)
end)

-- ── Cleanup ───────────────────────────────────────────────────────────────────
Players.PlayerRemoving:Connect(function(player)
	local model = carryingBrainrot[player]
	if model and model.Parent then
		local root = getRoot(model)
		local refPos = root and root.Position or Vector3.new(0, 5, 0)
		task.spawn(function()
			dropModel(model, refPos)
		end)
	end
	-- Add any currently-carried model to inventory before saving
	if model and model.Parent then
		local data = getPlayerData(player)
		local itemRecord = {
			name      = model.Name,
			icon      = model:GetAttribute("Icon") or "",
			modelName = model.Name,
		}
		local slot = nextFreeSlot(data)
		if slot then data.hotbar[slot] = itemRecord end
		table.insert(data.items, itemRecord)
	end
	savePlayerData(player)
	playerData[player]       = nil
	carryingBrainrot[player] = nil
	collectDebounce[player]  = nil
	pendingPlaceSlot[player] = nil
end)

-- ── Placement integration ─────────────────────────────────────────────────────
-- BindableFunctions in ServerStorage so PlacementServer can call them.
local placementBindables = Instance.new("Folder")
placementBindables.Name   = "PlacementBindables"
placementBindables.Parent = ServerStorage

-- RemoveEquippedItem(player) → itemRecord | nil
-- Removes the currently equipped item from the player's backpack and returns it.
-- Uses the client-reported slot (pendingPlaceSlot) for accuracy, falling back
-- to the server-tracked equipped slot.
local removeEquippedFunc      = Instance.new("BindableFunction")
removeEquippedFunc.Name       = "RemoveEquippedItem"
removeEquippedFunc.Parent     = placementBindables
removeEquippedFunc.OnInvoke   = function(player)
	local data = getPlayerData(player)
	-- Prefer the slot the client explicitly reported (more reliable than data.equipped)
	local slot = pendingPlaceSlot[player] or data.equipped
	pendingPlaceSlot[player] = nil  -- consume after use
	if not slot or not data.hotbar[slot] then return nil end

	local item = data.hotbar[slot]

	-- Do not allow placing tool items
	if TOOL_ITEMS[item.name] or TOOL_ITEMS[item.modelName] then
		print("[BackpackServer] Cannot place tool item:", item.name or item.modelName)
		return nil
	end

	-- Remove from hotbar
	data.hotbar[slot] = nil

	-- Remove from items list
	for i, v in ipairs(data.items) do
		if v == item then table.remove(data.items, i); break end
	end

	data.equipped = nil
	syncToClient(player)
	return item
end

-- AddItemToBackpack(player, itemRecord)
-- Returns an item to the player's backpack (hotbar first, bag otherwise).
local addItemFunc    = Instance.new("BindableFunction")
addItemFunc.Name     = "AddItemToBackpack"
addItemFunc.Parent   = placementBindables
addItemFunc.OnInvoke = function(player, itemRecord)
	if not itemRecord then return end
	local data = getPlayerData(player)
	local slot = nextFreeSlot(data)
	if slot then
		data.hotbar[slot] = itemRecord
		table.insert(data.items, itemRecord)
	else
		table.insert(data.items, itemRecord)
	end
	syncToClient(player)
end

-- ── BackpackAPI BindableFunction (for AdminRemote and future tooling) ─────────
-- Supported actions:
--   "ClearInventory", player  — wipes all items except TOOL_ITEMS, then saves
local backpackAPI        = Instance.new("BindableFunction")
backpackAPI.Name         = "BackpackAPIBindable"
backpackAPI.Parent       = ServerStorage
backpackAPI.OnInvoke     = function(action, player)
	if action == "ClearInventory" then
		if not player then return false end
		local data = getPlayerData(player)

		-- Collect placed items first so they are also cleared (not kept in world)
		local retrievePlaced = placementBindables:FindFirstChild("RetrievePlacedItems")
		if retrievePlaced then
			pcall(function() retrievePlaced:Invoke(player) end)
		end

		-- Remove everything that is not a tool
		local keepItems  = {}
		local keepHotbar = {}
		for _, item in ipairs(data.items) do
			if TOOL_ITEMS[item.name] or TOOL_ITEMS[item.modelName] then
				table.insert(keepItems, item)
			end
		end
		for slot, item in pairs(data.hotbar) do
			if TOOL_ITEMS[item.name] or TOOL_ITEMS[item.modelName] then
				keepHotbar[slot] = item
			end
		end

		data.items   = keepItems
		data.hotbar  = keepHotbar
		data.equipped = nil

		syncToClient(player)

		-- Persist immediately
		local savePayload = { hotbar = data.hotbar, items = data.items }
		pcall(function()
			backpackStore:SetAsync(tostring(player.UserId), savePayload)
		end)

		print("[BackpackServer] ClearInventory: cleared inventory for", player.Name)
		return true
	end
	return false
end

-- ── Save all players on server shutdown ───────────────────────────────────────
game:BindToClose(function()
	for _, player in ipairs(Players:GetPlayers()) do
		savePlayerData(player)
	end
end)

print("[BackpackServer] Ready")
