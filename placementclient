--
-- Client-side placement support:
--   • Monitors the "Place Brainrot" ProximityPrompt on every PlacePart.
--   • When the server sets PlacedByUserId on that prompt (item placed),
--     disables the prompt for any player who is NOT the owner so they
--     cannot see or trigger the "Pick Up" interaction.
--   • Re-enables the prompt for everyone when the item is picked up
--     (PlacedByUserId cleared).

local Players = game:GetService("Players")

local player = Players.LocalPlayer

-- ── Watch a single PlacePart prompt ──────────────────────────────────────────
local function watchPrompt(prompt)
local function refresh()
local placedBy = prompt:GetAttribute("PlacedByUserId")
if placedBy and placedBy ~= player.UserId then
-- Occupied by someone else → hide the prompt locally
prompt.Enabled = false
else
-- Empty slot OR I am the owner → show it
prompt.Enabled = true
end
end

refresh()
prompt:GetAttributeChangedSignal("PlacedByUserId"):Connect(refresh)
end

-- ── Watch a PlacePart for its prompts ─────────────────────────────────────────
local hookedParts = {}

local function watchPlacePart(placePart)
if hookedParts[placePart] then return end
hookedParts[placePart] = true

-- Handle any existing prompts
for _, d in ipairs(placePart:GetDescendants()) do
if d:IsA("ProximityPrompt") then watchPrompt(d) end
end
if placePart:IsA("BasePart") then
local p = placePart:FindFirstChildWhichIsA("ProximityPrompt")
if p then watchPrompt(p) end
end

-- Handle prompts added later
placePart.DescendantAdded:Connect(function(d)
if d:IsA("ProximityPrompt") then watchPrompt(d) end
end)
end

-- ── Watch workspace for PlacePart(s) ─────────────────────────────────────────
local function checkInstance(obj)
if obj.Name == "PlacePart" then watchPlacePart(obj) end
end

for _, child in ipairs(workspace:GetChildren()) do
checkInstance(child)
end
workspace.ChildAdded:Connect(checkInstance)

-- Also catch PlaceParts nested inside models or folders
workspace.DescendantAdded:Connect(function(d)
if d.Name == "PlacePart" then watchPlacePart(d) end
end)

print("[PlacementClient] Ready")
