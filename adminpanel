-- =====================================================
-- SUFFIX PARSER
-- =====================================================
local SUFFIXES = {k=1e3,m=1e6,b=1e9,t=1e12,q=1e15,qn=1e18}
local function parseAmount(str)
	if not str or str=="" then return nil end
	str = string.lower(str:match("^%s*(.-)%s*$"))
	local plain = tonumber(str); if plain then return math.floor(plain) end
	local num,suffix = str:match("^([%d%.]+)([a-z]+)$")
	if num and suffix and SUFFIXES[suffix] then return math.floor(tonumber(num)*SUFFIXES[suffix]) end
	return nil
end

-- =====================================================
-- NUMBER FORMATTER
-- =====================================================
local FMT_SUFFIXES = {
	"K","M","B","T",
	"Qa","Qi","Sx","Sp","Oc","No",
	"Dc","UDc","DDc","TDc","QaDc","QiDc","SxDc","SpDc","OcDc","NoDc",
	"Vg","UVg","DVg","TVg","QaVg","QiVg","SxVg","SpVg","OcVg","NoVg",
}
local function formatAmount(n)
	n = tonumber(n) or 0
	local abs = math.abs(n)
	for i = #FMT_SUFFIXES, 1, -1 do
		local threshold = 10 ^ (i * 3)
		if abs >= threshold then
			local val = n / threshold
			if val == math.floor(val) then
				return tostring(math.floor(val)) .. FMT_SUFFIXES[i]
			else
				return string.format("%.1f", val) .. FMT_SUFFIXES[i]
			end
		end
	end
	return tostring(math.floor(n))
end

