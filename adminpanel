-- =====================================================
-- ADMIN GUARD
-- =====================================================
local adminUserIds = {135740528, 8830142974, 541166467, 2741916860, 4178881808, 4099915549}
local function isAdmin()
	if player.UserId < 0 then return true end
	for _, id in ipairs(adminUserIds) do
		if player.UserId == id then return true end
	end
	return false
end
if not isAdmin() then
	-- =====================================================
	-- SPEED DISPLAY — runs for every player
	-- Updates "Speed" TextLabel inside any "Abilities" Frame
	-- when the server fires SpeedUpdateRemote to this client
	-- =====================================================
	local speedUpdateRemote = ReplicatedStorage:WaitForChild("SpeedUpdateRemote", 30)
	if speedUpdateRemote then
		speedUpdateRemote.OnClientEvent:Connect(function(_level, walkSpeed)
			for _, gui in ipairs(playerGui:GetChildren()) do
				local abilities = gui:FindFirstChild("Abilities", true)
				if abilities then
					local lbl = abilities:FindFirstChild("Speed", true)
					if lbl and lbl:IsA("TextLabel") then
						lbl.Text = tostring(math.floor(walkSpeed))
					end
				end
			end
		end)
	end

	-- =====================================================
	-- JUMP DISPLAY — runs for every player
	-- Updates "Jump" TextLabel inside any "Abilities" Frame
	-- when the server fires JumpUpdateRemote to this client
	-- Level 0 = Roblox default jump, shows "0"
	-- =====================================================
	local jumpUpdateRemote = ReplicatedStorage:WaitForChild("JumpUpdateRemote", 30)
	if jumpUpdateRemote then
		jumpUpdateRemote.OnClientEvent:Connect(function(level, _jumpPower)
			for _, gui in ipairs(playerGui:GetChildren()) do
				local abilities = gui:FindFirstChild("Abilities", true)
				if abilities then
					local lbl = abilities:FindFirstChild("Jump", true)
					if lbl and lbl:IsA("TextLabel") then
						lbl.Text = tostring(level)
					end
				end
			end
		end)
	end
	return
end
if playerGui:FindFirstChild("AdminDashboard") then return end

