-- =====================================================
local freeCamActive=false; local freeCamConn=nil; local freeCamMouseConn=nil
local freeCamHint=nil; local savedCamType=nil; local freeCamSpeed=30
local freeCamKeys={w=false,a=false,s=false,d=false,e=false}
local freeCamYaw=0; local freeCamPitch=0; local freeCamPos=Vector3.zero

local function stopFreeCam()
	if not freeCamActive then return end; freeCamActive=false
	if freeCamConn then freeCamConn:Disconnect(); freeCamConn=nil end
	if freeCamMouseConn then freeCamMouseConn:Disconnect(); freeCamMouseConn=nil end
	camera.CameraType = savedCamType or Enum.CameraType.Custom
	local char=player.Character
	if char then
		local hum=char:FindFirstChildOfClass("Humanoid")
		local root=char:FindFirstChild("HumanoidRootPart")
		if hum then hum.WalkSpeed=16; hum.JumpPower=50; hum.PlatformStand=false end
		if root then camera.CFrame=CFrame.new(root.Position+Vector3.new(0,2,5),root.Position) end
	end
	UserInputService.MouseBehavior=Enum.MouseBehavior.Default
	for k in pairs(freeCamKeys) do freeCamKeys[k]=false end
	if freeCamHint and freeCamHint.Parent then
		TweenService:Create(freeCamHint,TweenInfo.new(0.3),{BackgroundTransparency=1}):Play()
		task.delay(0.35,function()
			if freeCamHint and freeCamHint.Parent then freeCamHint:Destroy(); freeCamHint=nil end
		end)
	end
	showFeedback("Free cam OFF")
end

local function startFreeCam()
	if freeCamActive then return end; freeCamActive=true
	savedCamType=camera.CameraType; camera.CameraType=Enum.CameraType.Scriptable
	local char=player.Character
	if char then
		local hum=char:FindFirstChildOfClass("Humanoid")
		if hum then hum.WalkSpeed=0; hum.JumpPower=0; hum.PlatformStand=true end
	end
	local cf=camera.CFrame; freeCamPos=cf.Position; local look=cf.LookVector
	freeCamYaw=math.atan2(-look.X,-look.Z); freeCamPitch=math.asin(math.clamp(look.Y,-1,1))
	UserInputService.MouseBehavior=Enum.MouseBehavior.LockCenter
	freeCamHint=Instance.new("TextLabel"); freeCamHint.Size=UDim2.new(0,500,0,32)
	freeCamHint.AnchorPoint=Vector2.new(0.5,0); freeCamHint.Position=UDim2.new(0.5,0,0,10)
	freeCamHint.BackgroundColor3=C.winBg; freeCamHint.BackgroundTransparency=0.10
	freeCamHint.Text="FREE CAM  —  Mouse=look  |  WASD=move  |  E=up  |  Q=exit"
	freeCamHint.TextColor3=C.winBorder; freeCamHint.Font=Enum.Font.GothamBold
	freeCamHint.TextSize=12; freeCamHint.ZIndex=30; freeCamHint.Parent=screenGui
	mkCorner(freeCamHint,UDim.new(0,4)); mkStroke(freeCamHint,C.winBorder,1.5)
	freeCamMouseConn=UserInputService.InputChanged:Connect(function(inp)
		if not freeCamActive then return end
		if inp.UserInputType==Enum.UserInputType.MouseMovement then
			freeCamYaw=freeCamYaw-inp.Delta.X*0.003
			freeCamPitch=math.clamp(freeCamPitch-inp.Delta.Y*0.003,-math.pi/2+0.05,math.pi/2-0.05)
		end
	end)
	freeCamConn=RunService.Heartbeat:Connect(function(dt)
		if not freeCamActive then return end
		local rotCF=CFrame.Angles(0,freeCamYaw,0)*CFrame.Angles(freeCamPitch,0,0)
		local lv=rotCF.LookVector; local rv=rotCF.RightVector; local mv=Vector3.zero
		if freeCamKeys.w then mv+=lv end; if freeCamKeys.s then mv-=lv end
		if freeCamKeys.d then mv+=rv end; if freeCamKeys.a then mv-=rv end
		if freeCamKeys.e then mv+=Vector3.new(0,1,0) end
		if mv.Magnitude>0 then freeCamPos+=mv.Unit*freeCamSpeed*dt end
		camera.CFrame=CFrame.new(freeCamPos)*rotCF
	end)
	showFeedback("Free cam ON — Q to exit")
end

UserInputService.InputBegan:Connect(function(inp,gpe)
	if gpe then return end; if not freeCamActive then return end
	local k=inp.KeyCode
	if k==Enum.KeyCode.W then freeCamKeys.w=true
	elseif k==Enum.KeyCode.A then freeCamKeys.a=true
	elseif k==Enum.KeyCode.S then freeCamKeys.s=true
	elseif k==Enum.KeyCode.D then freeCamKeys.d=true
	elseif k==Enum.KeyCode.E then freeCamKeys.e=true
	elseif k==Enum.KeyCode.Q then stopFreeCam() end
end)
UserInputService.InputEnded:Connect(function(inp)
	if not freeCamActive then return end; local k=inp.KeyCode
	if k==Enum.KeyCode.W then freeCamKeys.w=false
	elseif k==Enum.KeyCode.A then freeCamKeys.a=false
	elseif k==Enum.KeyCode.S then freeCamKeys.s=false
	elseif k==Enum.KeyCode.D then freeCamKeys.d=false
	elseif k==Enum.KeyCode.E then freeCamKeys.e=false end
end)

-- =====================================================
-- FLY SYSTEM
-- =====================================================
local flyEnabled=false; local flySpd=50
local flyBodyVel=nil; local flyBodyGyro=nil; local flyConn=nil
local flyKeys={w=false,a=false,s=false,d=false}

local function getCharParts()
	local char=player.Character; if not char then return nil,nil,nil end
	return char,char:FindFirstChild("HumanoidRootPart"),char:FindFirstChildOfClass("Humanoid")
end

local flyStatusLbl=nil
local flyTogBtn=nil

local function enableFly()
	local _,root,hum=getCharParts(); if not root or not hum then return end
	flyEnabled=true; hum.PlatformStand=true
	flyBodyVel=Instance.new("BodyVelocity"); flyBodyVel.MaxForce=Vector3.new(1e6,1e6,1e6)
	flyBodyVel.Velocity=Vector3.zero; flyBodyVel.Parent=root
	flyBodyGyro=Instance.new("BodyGyro"); flyBodyGyro.MaxTorque=Vector3.new(1e6,1e6,1e6)
	flyBodyGyro.P=1e5; flyBodyGyro.D=500; flyBodyGyro.CFrame=root.CFrame; flyBodyGyro.Parent=root
	flyConn=RunService.Heartbeat:Connect(function()
		local _,r2,_=getCharParts(); if not r2 or not flyEnabled then return end
		local cf=camera.CFrame; local lv=cf.LookVector; local rv=cf.RightVector
		local dir=Vector3.zero
		if flyKeys.w then dir+=lv end; if flyKeys.s then dir-=lv end
		if flyKeys.d then dir+=rv end; if flyKeys.a then dir-=rv end
		if dir.Magnitude>0 then dir=dir.Unit end
		if flyBodyVel and flyBodyVel.Parent then
			flyBodyVel.Velocity=flyBodyVel.Velocity:Lerp(dir*flySpd,0.20)
		end
		local ff=Vector3.new(lv.X,0,lv.Z)
		if flyBodyGyro and flyBodyGyro.Parent and ff.Magnitude>0.01 then
			flyBodyGyro.CFrame=CFrame.new(r2.Position,r2.Position+ff.Unit)
		end
	end)
end

local function disableFly()
	flyEnabled=false
	if flyConn then flyConn:Disconnect(); flyConn=nil end
	if flyBodyVel and flyBodyVel.Parent then flyBodyVel:Destroy() end; flyBodyVel=nil
	if flyBodyGyro and flyBodyGyro.Parent then flyBodyGyro:Destroy() end; flyBodyGyro=nil
	local _,_,hum=getCharParts(); if hum then hum.PlatformStand=false end
end

UserInputService.InputBegan:Connect(function(inp,gpe)
	if gpe or freeCamActive then return end; local k=inp.KeyCode
	if k==Enum.KeyCode.W then flyKeys.w=true
	elseif k==Enum.KeyCode.A then flyKeys.a=true
	elseif k==Enum.KeyCode.S then flyKeys.s=true
	elseif k==Enum.KeyCode.D then flyKeys.d=true
	elseif k==Enum.KeyCode.E and flyEnabled then
		disableFly()
		if flyStatusLbl then flyStatusLbl.Text='<font color="rgb(135,145,145)">Status:</font>  <font color="rgb(215,55,55)"><b>Off</b></font>' end
		if flyTogBtn then flyTogBtn.Text="ENABLE FLY"; flyTogBtn.BackgroundColor3=C.flyBtn end
		showFeedback("Fly OFF (key E)")
	end
end)
UserInputService.InputEnded:Connect(function(inp)
	if freeCamActive then return end; local k=inp.KeyCode
	if k==Enum.KeyCode.W then flyKeys.w=false
	elseif k==Enum.KeyCode.A then flyKeys.a=false
	elseif k==Enum.KeyCode.S then flyKeys.s=false
	elseif k==Enum.KeyCode.D then flyKeys.d=false end
end)
player.CharacterAdded:Connect(function()
	flyEnabled=false; flyBodyVel=nil; flyBodyGyro=nil
	if flyConn then flyConn:Disconnect(); flyConn=nil end
	for k in pairs(flyKeys) do flyKeys[k]=false end
	if freeCamActive then stopFreeCam() end
end)

