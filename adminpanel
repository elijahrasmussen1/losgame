		for _,ch in ipairs(logScroll:GetChildren()) do if ch:IsA("Frame") then ch:Destroy() end end
		local emptyLbl=logScroll:FindFirstChild("EmptyLabel"); if emptyLbl then emptyLbl:Destroy() end
