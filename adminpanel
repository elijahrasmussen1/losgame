local function mkCorner(p, r)
	local c = Instance.new("UICorner")
	c.CornerRadius = r or UDim.new(0, 4)
	c.Parent = p
	return c
end

local function mkStroke(p, col, th)
	local s = Instance.new("UIStroke")
	s.Color           = col or C.inputBdr
	s.Thickness       = th or 1
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent          = p
	return s
end

local function mkBtn(parent, lbl, bg, bgDk, w, h, xPos, yPos, cb)
	local btn                    = Instance.new("TextButton")
	btn.Size                     = UDim2.new(0, w, 0, h)
	btn.Position                 = UDim2.new(0, xPos, 0, yPos)
	btn.BackgroundColor3         = bg
	btn.Text                     = lbl
	btn.TextColor3               = C.white
	btn.Font                     = Enum.Font.GothamBold
	btn.TextSize                 = 12
	btn.AutoButtonColor          = false
	btn.BorderSizePixel          = 0
	btn.TextStrokeColor3         = C.black
	btn.TextStrokeTransparency   = 0.65
	btn.Parent                   = parent
	mkCorner(btn, UDim.new(0, 4))
	local isDown = false
	btn.MouseEnter:Connect(function()
		if not isDown then TweenService:Create(btn, TF, {BackgroundColor3 = bgDk}):Play() end
	end)
	btn.MouseLeave:Connect(function()
		isDown = false
		TweenService:Create(btn, TF, {BackgroundColor3 = bg}):Play()
	end)
	btn.MouseButton1Down:Connect(function()
		isDown = true
		btn.BackgroundColor3 = Color3.fromRGB(
			math.max(bgDk.R*255-20,0), math.max(bgDk.G*255-20,0), math.max(bgDk.B*255-20,0))
	end)
	btn.MouseButton1Up:Connect(function()
		isDown = false
		TweenService:Create(btn, TF, {BackgroundColor3 = bg}):Play()
		if cb then task.spawn(cb) end
	end)
	return btn
end

